cat > .gitignore << 'EOF'
# Local .terraform directories
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfstate.lock.info

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Backend configuration
backend.hcl

# Environment variable files
.env
.envrc
*.tfvars
!environments/*/terraform.tfvars
!*.tfvars.example

# Sensitive files
**/*.pem
**/*.key
**/*.priv
**/secrets.*

# OS specific
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE specific
.vscode/
.idea/
*.iml

# Jenkins workspace
workspace/
*.log

# SSH keys
id_rsa
id_rsa.pub
*.pem
EOF